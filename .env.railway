# Copy these into Railway → your web service → Variables.
# Do NOT commit real secrets; this file is a checklist only.

APP_NAME="Corporate Haider"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://YOUR-SERVICE.up.railway.app

# Required. Generate locally with: php artisan key:generate --show
APP_KEY=

# No MySQL needed for this portfolio site — use file-based drivers:
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Optional: omit DB_* entirely, or use SQLite on the ephemeral disk:
# DB_CONNECTION=sqlite

LOG_CHANNEL=stderr
LOG_LEVEL=error
